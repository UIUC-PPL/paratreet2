# Common path/flag definitions for the ParaTreeT core library and examples.
# BASE_PATH is derived from the location of this file (src/Makefile.common),
# so the tree can live anywhere.
BASE_PATH := $(abspath $(dir $(lastword $(MAKEFILE_LIST)))/..)
PARATREET_PATH = $(BASE_PATH)/src
STRUCTURE_PATH = $(BASE_PATH)/utility/structures
UNION_FIND_DIR = $(BASE_PATH)/../unionfind
HTRAM_DIR = $(BASE_PATH)/../htram
PREFIX_LIB_DIR = $(UNION_FIND_DIR)/prefixLib

INCLUDES:=$(INCLUDES) -I$(STRUCTURE_PATH) -I$(PARATREET_PATH) -I$(PARATREET_PATH) -I$(PREFIX_LIB_DIR) -I$(UNION_FIND_DIR) -I$(HTRAM_DIR) -I.

# htram aggregation for the unionfind sibling. MUST MATCH how ../unionfind was
# built (its Makefile.common also defaults AGGREGATION on): unionFindLib.h
# changes class layout under this flag, so a mismatch is an ABI break. Both
# default ON; to build without htram, use `make AGGREGATION=` HERE AND in
# ../unionfind, and make clean everywhere in between.
# -DUNIONFIND rides along because AGGREGATION makes unionFindLib.h include
# htram_group.h, whose datatype selection needs that macro in every client TU
# (harmlessly duplicated where OPTS already define it).
AGGREGATION ?= -DAGGREGATION -DUNIONFIND
INCLUDES:=$(INCLUDES) $(AGGREGATION)
CHARM_HOME ?= $(HOME)/charm_reconverse

LD_LIBS:=$(LD_LIBS) -L$(PARATREET_PATH) -lparatreet -L$(UNION_FIND_DIR) -lunionFind -L${PREFIX_LIB_DIR} -lprefix -L${HTRAM_DIR} -lhtram_group_unionfind

# XDR library for Tipsy file I/O
# First check for system RPC XDR library, then fall back to utility/xdr
HAS_SYSTEM_XDR := $(shell printf '\043include <rpc/xdr.h>\n' | $(CC) -E - >/dev/null 2>&1 && echo yes)
ifeq ($(HAS_SYSTEM_XDR),yes)
	# Use system RPC XDR library
	# Try different library names depending on the system
	HAS_LIBRPC := $(shell $(CC) -lrpc -xc /dev/null -o /dev/null >/dev/null 2>&1 && echo yes)
	HAS_LIBTIRPC := $(shell $(CC) -ltirpc -xc /dev/null -o /dev/null >/dev/null 2>&1 && echo yes)
	ifeq ($(HAS_LIBRPC),yes)
		LD_LIBS:=$(LD_LIBS) -lrpc
	else ifeq ($(HAS_LIBTIRPC),yes)
		LD_LIBS:=$(LD_LIBS) -ltirpc
	endif
	# If neither library is needed, XDR functions are in libc (older glibc)
else
	# Fall back to utility/xdr library
	XDR_PATH=$(BASE_PATH)/utility/xdr
	ifneq (,$(wildcard $(XDR_PATH)/libxdr.a))
		INCLUDES:=$(INCLUDES) -I$(BASE_PATH)/utility/xdr
		LD_LIBS:=$(LD_LIBS) -L$(XDR_PATH) -lxdr
	endif
endif

# TIRPC is required on Summit
TIRPC_PATH?=/usr/include/tirpc
ifneq (,$(wildcard $(TIRPC_PATH)))
	INCLUDES:=$(INCLUDES) -I$(TIRPC_PATH)
	LD_LIBS:=$(LD_LIBS) -ltirpc
endif
